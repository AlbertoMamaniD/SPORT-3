# =============================================================
#  SPORT 3 - Plantilla de variables de entorno
#  Copia este archivo a .env y rellena con tus credenciales
# =============================================================

# --- BASE DE DATOS ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_password_aqui
POSTGRES_DB=sport_db
DB_PORT=5432

# --- PUERTOS EXPUESTOS ---
BACKEND_PORT=8080
FRONTEND_PORT=80

# --- BACKEND (SPRING BOOT) ---
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=tu_jwt_secret_aqui

# Cloudinary (subida de imagenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_UPLOAD_PRESET=tu_upload_preset

# Twilio (SMS)
TWILIO_ACCOUNT_SID=tu_twilio_sid
TWILIO_AUTH_TOKEN=tu_twilio_token
TWILIO_PHONE_NUMBER=+tu_numero

# --- FRONTEND (REACT / VITE) ---
# URL del backend que el frontend usara al compilarse
VITE_API_URL=http://localhost:8080
